{
  "name": "d2_tama_refact",
  "private": true,
  "scripts": {
    "firebase:login": "firebase login",
    "firestore:deploy": "firebase deploy --only firestore:rules",
    "firestore:indexes:deploy": "firebase deploy --only firestore:indexes",
    "encyclopedia:audit": "node scripts/backfillUserEncyclopedia.js --dry-run",
    "encyclopedia:backfill": "node scripts/backfillUserEncyclopedia.js --apply",
    "profile:backfill": "node scripts/backfillUserProfile.js",
    "nickname:audit": "node scripts/auditNicknameIndex.js",
    "nickname:backfill": "node scripts/backfillNicknameIndex.js",
    "nickname:verify": "node scripts/verifyNicknameIndex.js",
    "nickname:cleanup": "node scripts/cleanupLegacyNicknameMetadata.js",
    "operator:backfill": "node scripts/migrateOperatorRoles.js",
    "notification-subscribers:audit": "node scripts/backfillNotificationSubscribers.js --dry-run",
    "notification-subscribers:backfill": "node scripts/backfillNotificationSubscribers.js --apply",
    "notification:diagnose-slot": "node scripts/diagnoseSlotNotificationState.js",
    "arena:ghost:audit": "node scripts/auditArenaGhostReadiness.js",
    "arena:identity:backfill": "node scripts/backfillArenaCombatIdentity.js",
    "arena:ghost:migrate": "node scripts/migrateArenaGhosts.js",
    "test:notification-api": "node --test tests/api/notificationReports.test.js tests/api/notificationSubscribers.test.js tests/api/urgentCareNotifications.test.js tests/apps-script-urgent-care.test.js tests/notification-entrypoints.test.js tests/notification-subscriber-backfill.test.js",
    "test:encyclopedia-migration": "node --test tests/encyclopedia-migration.test.js",
    "test:nickname-migration": "node --test tests/nickname-index-migration.test.js",
    "test:community-api": "node --test tests/community-lib.test.js tests/api/community.test.js",
    "test:frontend": "npm --prefix digimon-tamagotchi-frontend run test -- --watchAll=false --runInBand",
    "test:server": "env -i PATH=\"$PATH\" HOME=\"/tmp/d2-test-no-credentials-$$\" node --test \"digimon-tamagotchi-frontend/api/_lib/*.test.js\" \"tests/*.test.js\" \"tests/api/*.test.js\"",
    "build:frontend": "npm --prefix digimon-tamagotchi-frontend run build",
    "check": "npm run test:frontend && npm run test:server && npm run check:api-single-source && npm run build:frontend && npm run check:server-projection",
    "check:api-single-source": "node scripts/checkApiSingleSource.js",
    "build:server-projection": "node scripts/buildServerGameProjection.js",
    "check:server-projection": "node scripts/checkServerGameProjection.js",
    "test:firestore-emulator": "firebase emulators:exec --only firestore \"node --test tests/firestore-emulator.test.js\"",
    "test:arena-emulator": "firebase emulators:exec --only firestore \"node --test --test-concurrency=1 tests/arena-firestore-rules.test.js tests/arena-transaction-emulator.test.js tests/arena-ghost-emulator.test.js tests/arena-battle-emulator.test.js tests/arena-ghost-migration-emulator.test.js\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "@vercel/analytics": "^1.6.1",
    "firebase-admin": "^13.7.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.16.0",
    "firebase-tools": "^13.0.0"
  }
}
